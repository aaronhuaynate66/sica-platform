# =========================================================================
# SICA API — environment template
# Copy to .env (NEVER commit .env — it is .gitignored).
# =========================================================================

# Anthropic API key for clinical-extractor (required for POST /extract).
# If missing, the API still starts but /extract returns 503.
ANTHROPIC_API_KEY=

# Modelo Claude por default (override del extractor). Opcional.
# CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Tamaño máximo de archivo aceptado por POST /extract, en megabytes.
# Default: 10
MAX_FILE_SIZE_MB=10

# Orígenes permitidos para CORS, comma-separated. Default: localhost:3000 (la web).
ALLOWED_ORIGINS=http://localhost:3000

# Regex de orígenes permitidos (patrones, no literales). Default cubre
# previews de Vercel (*.vercel.app). Refinar con dominio de producción
# cuando se sepa, por ejemplo:
#   ALLOWED_ORIGIN_REGEX=^https://(app|api|.*\.preview)\.sica\.example\.com$
ALLOWED_ORIGIN_REGEX=^https://([a-z0-9-]+\.)*vercel\.app$

# Nivel de log estructurado. Valores: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
