# =========================================================================
# SICA web — environment template
# Copia este archivo a `.env.local` (gitignored) para desarrollo local.
# Variables marcadas NEXT_PUBLIC_* se inyectan al bundle del cliente.
# =========================================================================

# -------------------------------------------------------------------------
# Backend sica-api
# -------------------------------------------------------------------------
# URL del backend sica-api. Default local: http://localhost:8000
# Producción: https://sica-api-d1gq.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# Modo de operación de la UI:
# - "demo": usa fixture sintético, NO llama al backend.
# - "live": intenta usar el backend; si /health falla, cae automáticamente a demo.
NEXT_PUBLIC_API_MODE=demo

# -------------------------------------------------------------------------
# Supabase (auth + DB + storage)
# -------------------------------------------------------------------------
# Project URL — Dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Anon public key — Dashboard → Settings → API → Project API keys → anon public
# Seguro exponer al cliente: las policies RLS aplican.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# =========================================================================
# Analytics (opcional). Los scripts SOLO se cargan si:
#   1) la variable correspondiente está definida y no vacía, Y
#   2) el usuario consintió explícitamente desde el ConsentBanner.
# Dejar vacío en repo; pegar los IDs reales en Vercel UI.
# =========================================================================

# Google Analytics 4 Measurement ID. Formato: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Microsoft Clarity Project ID. Formato: cadena alfanumérica corta.
NEXT_PUBLIC_CLARITY_PROJECT_ID=
