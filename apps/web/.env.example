# =========================================================================
# SICA web — environment template
# Copia este archivo a `.env.local` (gitignored) para desarrollo local.
# Variables marcadas NEXT_PUBLIC_* se inyectan al bundle del cliente.
# =========================================================================

# URL del backend sica-api. Default: http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Modo de operación de la UI:
# - "demo": usa fixture sintético, NO llama al backend.
# - "live": intenta usar el backend; si /health falla, cae automáticamente a demo.
NEXT_PUBLIC_API_MODE=demo
