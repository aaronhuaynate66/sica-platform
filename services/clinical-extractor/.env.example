# =========================================================================
# clinical-extractor — variables de entorno
# Copia este archivo a `.env` y completa los valores.
# El archivo `.env` NUNCA se commitea (está en .gitignore).
# =========================================================================

# API key de Anthropic. Obtener en https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Modelo Claude usado para la extracción.
# Default ancla en sonnet 4.5; cambiar requiere ADR.
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Máximo de tokens en la respuesta del modelo.
CLAUDE_MAX_TOKENS=4096

# Timeout en segundos para la llamada al modelo.
CLAUDE_TIMEOUT_SECONDS=60

# Si true, imprime el JSON crudo del modelo además del Pydantic validado.
DEBUG_RAW_OUTPUT=false
