# =========================================================================
# SICA Platform — .gitignore
# Política: por defecto NUNCA se commitea PHI ni secretos. Cualquier
# excepción debe ser explícita, nominal y marcada como sintética.
# =========================================================================

# Documentos en proceso / borradores no commiteables
*.draft.md
.scratch/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editors
.vscode/
.idea/
*.swp
*.swo
*~
.cursor/
.claude/

# Secretos — defensiva. .env nunca se commitea.
.env
.env.local
.env.*.local
.env.production
*.key
*.pem
credentials.json
service-account*.json
.secrets/

# Datos clínicos — NUNCA commitear datos reales
data/
patients/
*.csv
*.xlsx
*.dcm
*.fhir.json
phi/
historias/

# PDFs por defecto bloqueados (pueden contener PHI)
*.pdf

# EXCEPCIONES EXPLÍCITAS — solo para datos 100% sintéticos y marcados
# Cada excepción aquí debe estar explícitamente revisada por un humano
# y el contenido debe llevar el header "DATOS SINTÉTICOS - NO ES PACIENTE REAL".
!services/clinical-extractor/data/
!services/clinical-extractor/data/synthetic_case_01.pdf
!services/clinical-extractor/data/synthetic_case_02_preeclampsia.pdf
!services/clinical-extractor/data/synthetic_case_03_gemelar.pdf
!services/clinical-extractor/data/synthetic_case_04_rpm.pdf
!services/clinical-extractor/data/synthetic_case_05_diabetes_gestacional.pdf
!services/clinical-extractor/data/synthetic_case_06_anemia_severa.pdf
!services/clinical-extractor/data/synthetic_case_07_manuscrito.pdf
!evals/fixtures/
!evals/fixtures/**/*.pdf
# UI demo: copia local del PDF sintético para la app web. Marcado como demo.
!apps/web/public/synthetic_case_01.pdf

# sica-evals: reportes generados por el harness — NUNCA commitear
# (cada corrida produce *.json/*.md/*.html con timestamps + run_id).
evals/reports/*
!evals/reports/.gitkeep
# Excepción explícita: los baselines persistidos en evals/fixtures/baselines/
# SÍ se commitean (son snapshots firmados de corridas que pasaron gates).
# Documentado en evals/fixtures/baselines/README.md.
!evals/fixtures/baselines/
!evals/fixtures/baselines/**
# Datasets y ground truth reales: nunca en el repo. Ver docs/security/data-handling.md.
evals/datasets/
evals/ground_truth/
# Build/dev artifacts del paquete sica-evals
evals/.pytest_cache/
evals/.mypy_cache/
evals/.ruff_cache/
evals/dist/
evals/build/

# =========================================================================
# Node / TypeScript
# =========================================================================
node_modules/
.pnpm-store/
.pnp/
.pnp.js
dist/
build/
out/
.next/
.turbo/
.cache/
*.tsbuildinfo
.eslintcache
coverage/
.nyc_output/

# =========================================================================
# Python
# =========================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.ipynb_checkpoints/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
htmlcov/
.coverage
.coverage.*
*.egg-info/
*.egg
pip-wheel-metadata/

# =========================================================================
# Logs y temporales
# =========================================================================
*.log
logs/
tmp/
.tmp/
